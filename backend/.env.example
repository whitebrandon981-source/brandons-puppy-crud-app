PORT=5001
DB_HOST=your-db-host.render.com
DB_PORT=5432
DB_SCHEMA=app
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://user:pass@host/dbname
PGSSLMODE=require
JWKS_URI=https://api.asgardeo.io/t/YOUR_ORG/oauth2/jwks
JWT_ISSUER=https://api.asgardeo.io/t/YOUR_ORG/oauth2/token
